{
  "name": "yt-dlp-desktop",
  "version": "0.1.0",
  "private": true,
  "main": "dist/desktop/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"wait-on http://127.0.0.1:5173 && npm run dev:electron\"",
    "dev:frontend": "vite --config frontend/vite.config.ts",
    "dev:backend": "python -m uvicorn app.main:app --host 127.0.0.1 --port 8000 --reload --app-dir backend",
    "dev:electron": "npm run build:electron && electron dist/desktop/main.js",
    "build:frontend": "vite build --config frontend/vite.config.ts",
    "build:electron": "tsc -p tsconfig.desktop.json",
    "build": "npm run build:frontend && npm run build:electron",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux"
  },
  "dependencies": {
    "axios": "^1.7.7",
    "pinia": "^2.2.2",
    "vue": "^3.5.10",
    "vue-router": "^4.4.5"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "@vitejs/plugin-vue": "^5.1.4",
    "concurrently": "^9.0.1",
    "electron": "^32.2.1",
    "electron-builder": "^24.13.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "vue-tsc": "^2.1.6",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.yueh.ytdlpgui",
    "productName": "YtDlpGui",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/desktop/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "frontend/dist",
        "to": "frontend-dist"
      },
      {
        "from": "backend",
        "to": "backend",
        "filter": [
          "**/*",
          "!**/__pycache__/**",
          "!**/.pytest_cache/**",
          "!tests/**",
          "!data/**"
        ]
      },
      {
        "from": "resources/bin",
        "to": "bin"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "${productName}-${version}-win-${arch}.${ext}"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.utilities",
      "artifactName": "${productName}-${version}-mac-${arch}.${ext}"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility",
      "artifactName": "${productName}-${version}-linux-${arch}.${ext}"
    }
  }
}
